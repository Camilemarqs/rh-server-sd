# Copie para .env e preencha após o deploy na nuvem
# API REST (ex: http://123.45.67.89:8080 ou https://seu-dominio.com)
API_URL=http://SEU_SERVIDOR:8080

# RabbitMQ (ex: amqp://guest:guest@123.45.67.89:5672)
RABBIT_URL=amqp://guest:guest@SEU_SERVIDOR:5672

# Credenciais do RabbitMQ (devem coincidir com o docker-compose)
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
